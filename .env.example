POSTGRES_USER=postgres
POSTGRES_ROOT_PASSWORD=password

APP_DB_USERNAME=gym_user
APP_DB_PASSWORD=password
APP_DB_NAME=gym_crm
TEST_DB_NAME=gym_crm_test

REPL_PASSWORD=password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

PGPOOL_BACKEND_NODES=0:gym-master:5432,1:gym-replica:5432
PGPOOL_ENABLE_LOAD_BALANCING=yes
PGPOOL_SR_CHECK_USER=postgres

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://gym-pgpool:5432/gym_crm

JWT_ISSUER=https://gym-crm.local
JWT_SECRET=GymCrmLocalDevelopmentJwtSecretKeyMustBeAtLeastThirtyTwoBytes
JWT_TOKEN_LIFETIME=PT30M

LOGIN_MAX_FAILED_ATTEMPTS=3
LOGIN_LOCK_DURATION=PT5M

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=PT1H

REDIS_HOST=gym-redis
REDIS_PORT=6379

EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://eureka:8761/eureka/

TRAINER_WORKLOAD_CONNECT_TIMEOUT=2s
TRAINER_WORKLOAD_READ_TIMEOUT=5s
TRAINER_WORKLOAD_DATASOURCE_URL=jdbc:h2:file:/app/data/trainer_workload;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
# розкоментувати для дебагу h2
#TRAINER_WORKLOAD_H2_TCP_ENABLED=true

SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# Default Prometheus config scrapes the containerized gym-app service.
# Use prometheus-host-podman.yml or prometheus-host-docker.yml when the app runs locally on the host.
PROMETHEUS_CONFIG=prometheus.yml
