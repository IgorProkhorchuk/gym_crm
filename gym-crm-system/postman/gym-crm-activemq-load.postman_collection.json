                "exec": [
                  "pm.test('Trainee created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('traineeUsername', body.username);",
                  "pm.collectionVariables.set('traineePassword', body.password);"
                ]
