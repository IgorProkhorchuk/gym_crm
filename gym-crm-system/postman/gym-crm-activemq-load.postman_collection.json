{
  "info": {
    "_postman_id": "41b1af82-1a2d-45e4-9a0d-gymcrmactivemq001",
    "name": "Gym CRM ActiveMQ Broker Load",
    "description": "Manual collection for putting load on the trainer workload ActiveMQ queue. Run it against the full stack. Open ActiveMQ console at http://localhost:8161/admin/ with admin/admin and watch Queues, gym-app logs, and gym-trainer-workload logs while the collection runs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  pm.collectionVariables.set('runId', Date.now().toString());",
          "}",
          "if (!pm.collectionVariables.get('loadIterations')) {",
          "  pm.collectionVariables.set('loadIterations', '12');",
          "}",
          "if (!pm.collectionVariables.get('currentIteration')) {",
          "  pm.collectionVariables.set('currentIteration', '0');",
          "}",
          "if (!pm.collectionVariables.get('expectedDuration')) {",
          "  pm.collectionVariables.set('expectedDuration', '0');",
          "}"
        ]
      }
    }
  ],
