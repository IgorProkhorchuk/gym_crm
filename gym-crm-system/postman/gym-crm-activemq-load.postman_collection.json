    {
      "name": "02 ActiveMQ Baseline",
      "item": [
        {
          "name": "Read Broker Totals",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Broker totals are readable', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const value = pm.response.json().value;",
                  "console.log('ActiveMQ totals:', value);",
                  "pm.test('trainer-workload has JMS consumers', function () {",
                  "  pm.expect(value.CurrentConnectionsCount).to.be.at.least(1);",
                  "  pm.expect(value.TotalConsumerCount).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{activeMqUsername}}",
                  "type": "string"
