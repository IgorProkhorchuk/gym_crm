            ],
            "url": {
              "raw": "{{activeMqBaseUrl}}/api/jolokia/read/org.apache.activemq:type=Broker,brokerName=localhost/CurrentConnectionsCount,TotalConsumerCount,TotalProducerCount,Queues",
              "host": [
