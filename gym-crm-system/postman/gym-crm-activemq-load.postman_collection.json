    {
      "name": "03 Publish ADD Batch",
      "item": [
        {
          "name": "Add Training Batch Item",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const iteration = Number(pm.collectionVariables.get('currentIteration') || '0') + 1;",
                  "const duration = 5 + iteration;",
                  "pm.collectionVariables.set('currentIteration', String(iteration));",
                  "pm.collectionVariables.set('currentDuration', String(duration));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Training creation publishes an outbox event', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const expectedDuration = Number(pm.collectionVariables.get('expectedDuration') || '0') + Number(pm.collectionVariables.get('currentDuration'));",
                  "pm.collectionVariables.set('expectedDuration', String(expectedDuration));",
                  "const currentIteration = Number(pm.collectionVariables.get('currentIteration'));",
                  "const loadIterations = Number(pm.collectionVariables.get('loadIterations'));",
                  "console.log('Published ADD candidate', currentIteration, 'of', loadIterations);",
                  "if (currentIteration < loadIterations) {",
                  "  postman.setNextRequest('Add Training Batch Item');",
                  "} else {",
                  "  postman.setNextRequest('Read Queue Metrics After ADD Batch');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"traineeUsername\": \"{{traineeUsername}}\",\n  \"trainerUsername\": \"{{trainerUsername}}\",\n  \"trainingName\": \"Broker load {{runId}} #{{currentIteration}}\",\n  \"trainingTypeName\": \"Fitness\",\n  \"trainingDate\": \"2026-06-01\",\n  \"trainingDuration\": {{currentDuration}}\n}"
            },
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainings",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainings"
              ]
            }
          }
        },
        {
          "name": "Read Queue Metrics After ADD Batch",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Queue metrics are readable after ADD batch', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "console.log('Queue metrics after ADD batch:', pm.response.json().value);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{activeMqUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{activeMqPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Origin",
                "value": "http://localhost:8161"
              }
            ],
            "url": {
              "raw": "{{activeMqBaseUrl}}/api/jolokia/read/org.apache.activemq:brokerName=localhost,destinationName={{queueName}},destinationType=Queue,type=Broker/ConsumerCount,QueueSize,EnqueueCount,DequeueCount",
              "host": [
                "{{activeMqBaseUrl}}"
              ],
              "path": [
                "api",
                "jolokia",
                "read",
                "org.apache.activemq:brokerName=localhost,destinationName={{queueName}},destinationType=Queue,type=Broker",
                "ConsumerCount,QueueSize,EnqueueCount,DequeueCount"
              ]
            }
          }
        },
        {
          "name": "Wait For ADD Drain",
          "description": "Waits for the outbox dispatcher and trainer-workload listener. Watch ActiveMQ QueueSize and DequeueCount in the console while this runs.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const waitUntil = Date.now() + 30000;",
                  "while (Date.now() < waitUntil) {}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gym API is available after ADD drain wait', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "url": {
              "raw": "{{gymBaseUrl}}/v1/training-types",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "training-types"
              ]
            }
          }
        },
        {
          "name": "Read Queue Metrics After ADD Drain",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Queue metrics are readable after ADD drain', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const value = pm.response.json().value;",
                  "console.log('Queue metrics after ADD drain:', value);",
                  "pm.test('Queue is drained after ADD batch', function () {",
                  "  pm.expect(value.QueueSize).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{activeMqUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{activeMqPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Origin",
                "value": "http://localhost:8161"
              }
            ],
            "url": {
              "raw": "{{activeMqBaseUrl}}/api/jolokia/read/org.apache.activemq:brokerName=localhost,destinationName={{queueName}},destinationType=Queue,type=Broker/ConsumerCount,QueueSize,EnqueueCount,DequeueCount",
              "host": [
                "{{activeMqBaseUrl}}"
              ],
              "path": [
                "api",
                "jolokia",
                "read",
                "org.apache.activemq:brokerName=localhost,destinationName={{queueName}},destinationType=Queue,type=Broker",
                "ConsumerCount,QueueSize,EnqueueCount,DequeueCount"
              ]
            }
          }
        },
        {
          "name": "Verify Workload Summary After ADD Batch",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Trainer workload is available after ADD batch', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "const expectedDuration = Number(pm.collectionVariables.get('expectedDuration'));",
                  "const year = (body.years || []).find(function (item) { return item.year === 2026; });",
                  "const month = year && (year.months || []).find(function (item) { return item.month === 6; });",
                  "pm.test('Workload duration matches ADD batch', function () {",
                  "  pm.expect(body.trainerUsername).to.eql(pm.collectionVariables.get('trainerUsername'));",
                  "  pm.expect(month, 'June 2026 workload month').to.exist;",
                  "  pm.expect(month.trainingSummaryDuration).to.eql(expectedDuration);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainer-workloads/{{trainerUsername}}",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainer-workloads",
                "{{trainerUsername}}"
              ]
            }
          }
        }
      ]
    },
