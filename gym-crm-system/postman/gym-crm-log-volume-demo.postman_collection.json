          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const newRunId = Date.now().toString();",
              "pm.collectionVariables.set('runId', newRunId);",
              "pm.collectionVariables.set('trainers', '[]');",
              "pm.collectionVariables.set('trainees', '[]');",
              "pm.collectionVariables.set('trainerIndex', '0');",
              "pm.collectionVariables.set('traineeIndex', '0');",
              "pm.collectionVariables.set('trainerLoginIndex', '0');",
              "pm.collectionVariables.set('traineeLoginIndex', '0');",
              "pm.collectionVariables.set('assignmentIndex', '0');",
              "pm.collectionVariables.set('trainingIndex', '0');",
              "pm.collectionVariables.set('readTraineeIndex', '0');",
              "pm.collectionVariables.set('readTrainerIndex', '0');",
              "pm.collectionVariables.set('workloadIndex', '0');",
              "pm.collectionVariables.set('deleteTraineeIndex', '0');",
              "pm.collectionVariables.set('autoTxIndex', '0');",
              "pm.collectionVariables.set('generatedTransactionIds', '[]');",
              "pm.collectionVariables.set('transactionId', 'postman-log-demo-' + newRunId + '-initialize-demo-run-' + Date.now());",
              "console.log('Log demo runId: ' + newRunId);",
              "console.log('Grafana run query: {job=\"gym-crm\"} |= \"postman-log-demo-' + newRunId + '\"');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Gym CRM is healthy before seeding logs', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('UP');",
              "});",
              "postman.setNextRequest('01 Create Trainer');"
            ]
          }
        }
