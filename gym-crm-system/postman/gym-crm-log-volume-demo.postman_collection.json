    {
      "name": "13 Auto Generated Transaction Id Check",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const index = Number(pm.collectionVariables.get('autoTxIndex') || 0);",
              "const trainees = JSON.parse(pm.collectionVariables.get('trainees') || '[]');",
              "const trainers = JSON.parse(pm.collectionVariables.get('trainers') || '[]');",
              "const deleteCount = Number(pm.collectionVariables.get('deleteTraineeCount') || 0);",
              "const trainee = trainees[Math.min(deleteCount, trainees.length - 1)];",
              "const trainer = trainers[index % trainers.length];",
              "",
              "const scenarios = [",
              "  {",
              "    name: 'training types',",
              "    path: '/v1/training-types',",
              "    token: trainee.token,",
              "    statuses: [200]",
              "  },",
              "  {",
              "    name: 'trainee profile',",
              "    path: '/v1/trainees/profile?username=' + encodeURIComponent(trainee.username),",
              "    token: trainee.token,",
              "    statuses: [200]",
              "  },",
              "  {",
              "    name: 'trainee trainings',",
              "    path: '/v1/trainees/trainings?username=' + encodeURIComponent(trainee.username) + '&fromDate=2026-07-01&toDate=2026-07-31',",
              "    token: trainee.token,",
              "    statuses: [200]",
              "  },",
              "  {",
              "    name: 'unassigned trainers',",
              "    path: '/v1/trainees/trainers/unassigned?username=' + encodeURIComponent(trainee.username),",
              "    token: trainee.token,",
              "    statuses: [200]",
              "  },",
              "  {",
              "    name: 'trainer profile',",
              "    path: '/v1/trainers/profile?username=' + encodeURIComponent(trainer.username),",
              "    token: trainer.token,",
              "    statuses: [200]",
              "  },",
              "  {",
              "    name: 'trainer trainings',",
              "    path: '/v1/trainers/trainings?username=' + encodeURIComponent(trainer.username) + '&fromDate=2026-07-01&toDate=2026-07-31',",
              "    token: trainer.token,",
              "    statuses: [200]",
              "  },",
              "  {",
              "    name: 'trainer workload',",
              "    path: '/v1/trainer-workloads/' + encodeURIComponent(trainer.username),",
              "    token: trainee.token,",
              "    statuses: [200, 404]",
              "  },",
              "  {",
              "    name: 'invalid date query',",
              "    path: '/v1/trainees/trainings?username=' + encodeURIComponent(trainee.username) + '&fromDate=wrong-date',",
              "    token: trainee.token,",
              "    statuses: [400]",
              "  },",
              "  {",
              "    name: 'forbidden trainer profile by trainee token',",
              "    path: '/v1/trainers/profile?username=' + encodeURIComponent(trainer.username),",
              "    token: trainee.token,",
              "    statuses: [403]",
              "  },",
              "  {",
              "    name: 'missing training delete lookup via get trainings fallback',",
              "    path: '/v1/trainees/trainings?username=' + encodeURIComponent(trainee.username) + '&fromDate=2026-01-01&toDate=2026-12-31&trainingType=Fitness',",
              "    token: trainee.token,",
              "    statuses: [200]",
              "  }",
              "];",
              "",
              "const scenario = scenarios[index % scenarios.length];",
              "pm.collectionVariables.set('currentAutoTxScenario', scenario.name);",
              "pm.collectionVariables.set('currentAutoTxPath', scenario.path);",
              "pm.collectionVariables.set('currentAutoTxAuthorization', 'Bearer ' + scenario.token);",
              "pm.collectionVariables.set('currentAutoTxExpectedStatuses', JSON.stringify(scenario.statuses));",
              "console.log('Auto-generated tx check #' + (index + 1) + ': ' + scenario.name + ' ' + scenario.path);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const expectedStatuses = JSON.parse(pm.collectionVariables.get('currentAutoTxExpectedStatuses') || '[200]');",
              "pm.test('Auto transaction-id scenario returns expected status', function () {",
              "  pm.expect(expectedStatuses).to.include(pm.response.code);",
              "});",
              "",
              "const generatedTransactionId = pm.response.headers.get('X-Transaction-Id');",
              "pm.test('Response contains generated X-Transaction-Id', function () {",
              "  pm.expect(generatedTransactionId).to.be.a('string').and.not.empty;",
              "  pm.expect(generatedTransactionId).to.not.include('postman-log-demo-');",
              "});",
              "",
              "const generatedIds = JSON.parse(pm.collectionVariables.get('generatedTransactionIds') || '[]');",
              "generatedIds.push(generatedTransactionId);",
              "pm.collectionVariables.set('generatedTransactionIds', JSON.stringify(generatedIds));",
              "console.log('Generated X-Transaction-Id: ' + generatedTransactionId);",
              "console.log('Grafana query: {job=\"gym-crm\"} |= \"tx:' + generatedTransactionId + '\"');",
              "",
              "const nextIndex = Number(pm.collectionVariables.get('autoTxIndex')) + 1;",
              "pm.collectionVariables.set('autoTxIndex', String(nextIndex));",
              "if (nextIndex < Number(pm.collectionVariables.get('autoTxCount'))) {",
              "  postman.setNextRequest('13 Auto Generated Transaction Id Check');",
              "} else {",
              "  postman.setNextRequest('14 Finish And Print Grafana Queries');",
              "}"
            ]
          }
        }
      ],
