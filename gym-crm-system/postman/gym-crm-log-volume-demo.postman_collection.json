    {
      "name": "01 Create Trainer",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const index = Number(pm.collectionVariables.get('trainerIndex') || 0);",
              "const specializations = ['Fitness', 'Yoga', 'Cardio', 'Boxing'];",
              "pm.collectionVariables.set('currentTrainerNumber', String(index + 1).padStart(2, '0'));",
              "pm.collectionVariables.set('currentTrainerSpecialization', specializations[index % specializations.length]);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Trainer is created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "const trainers = JSON.parse(pm.collectionVariables.get('trainers') || '[]');",
              "trainers.push({",
              "  username: body.username,",
              "  password: body.password,",
              "  specialization: pm.collectionVariables.get('currentTrainerSpecialization')",
              "});",
              "pm.collectionVariables.set('trainers', JSON.stringify(trainers));",
              "",
              "const nextIndex = Number(pm.collectionVariables.get('trainerIndex')) + 1;",
              "pm.collectionVariables.set('trainerIndex', String(nextIndex));",
              "if (nextIndex < Number(pm.collectionVariables.get('trainerCount'))) {",
              "  postman.setNextRequest('01 Create Trainer');",
              "} else {",
              "  postman.setNextRequest('02 Create Trainee');",
              "}"
            ]
          }
        }
      ],
