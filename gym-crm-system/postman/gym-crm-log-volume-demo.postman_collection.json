{
  "info": {
    "_postman_id": "4ef8b9a2-7b2d-4b22-9b31-gymcrmlogdemo01",
    "name": "Gym CRM Log Volume Demo",
    "description": "Creates multiple trainers, trainees, trainings, read requests, expected failures, partial cleanup, and auto-generated transaction-id checks to generate centralized logs for Loki/Grafana. Run the collection from top to bottom with Postman Collection Runner. Most requests send X-Transaction-Id like postman-log-demo-<runId>-<request>-<timestamp>; the auto-generated checks intentionally omit the header and capture the generated X-Transaction-Id from response headers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:8080/api');",
          "}",
          "",
          "const runId = pm.collectionVariables.get('runId') || Date.now().toString();",
          "pm.collectionVariables.set('runId', runId);",
          "",
          "const requestSlug = pm.info.requestName",
          "  .toLowerCase()",
          "  .replace(/[^a-z0-9]+/g, '-')",
          "  .replace(/^-|-$/g, '');",
          "const transactionId = 'postman-log-demo-' + runId + '-' + requestSlug + '-' + Date.now();",
          "pm.collectionVariables.set('transactionId', transactionId);",
          "console.log('X-Transaction-Id: ' + transactionId);"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "runId",
      "value": "",
      "type": "string"
    },
    {
      "key": "trainerCount",
      "value": "4",
      "type": "string"
    },
    {
      "key": "traineeCount",
      "value": "6",
      "type": "string"
    },
    {
      "key": "trainingCount",
      "value": "18",
      "type": "string"
    },
    {
      "key": "deleteTraineeCount",
      "value": "2",
      "type": "string"
    },
    {
      "key": "autoTxCount",
      "value": "10",
