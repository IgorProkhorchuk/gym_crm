              "const runId = pm.collectionVariables.get('runId');",
              "const generatedIds = JSON.parse(pm.collectionVariables.get('generatedTransactionIds') || '[]');",
              "console.log('Demo run finished. Grafana Loki queries:');",
              "console.log('{job=\"gym-crm\"} |= \"postman-log-demo-' + runId + '\"');",
              "console.log('{service=~\"gym-crm-system|trainer-workload\"} |= \"postman-log-demo-' + runId + '\"');",
              "generatedIds.forEach(function (id) {",
              "  console.log('{job=\"gym-crm\"} |= \"tx:' + id + '\"');",
              "});",
              "console.log('{service=~\"gym-crm-system|trainer-workload\"} |= \"ERROR\"');",
              "postman.setNextRequest(null);"
            ]
          }
        }
