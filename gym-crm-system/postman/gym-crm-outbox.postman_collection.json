{
  "info": {
    "_postman_id": "2c820dc7-4eaf-4e73-bbe6-gymcrmoutbox001",
    "name": "Gym CRM Outbox Retry",
    "description": "Manual collection for checking gym-crm-system -> trainer-workload integration and outbox retry. Run requests from top to bottom. Workload summaries are read through gym-crm-system because trainer-workload is an internal service. For the retry section, pause after the manual step, stop trainer-workload with `docker-compose stop trainer-workload`, run the failed-delivery request, then start it again with `docker-compose start trainer-workload`. Optional DB check: `docker exec -e PGPASSWORD=password gym-master psql -U gym_user -d gym_crm -c \"select id, training_id, trainer_username, action_type, status, retry_count, next_retry_at, error_message from trainer_workload_outbox order by id;\"`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  pm.collectionVariables.set('runId', Date.now().toString());",
          "}",
          "if (!pm.collectionVariables.get('expectedDuration')) {",
          "  pm.collectionVariables.set('expectedDuration', '0');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "gymBaseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "runId",
      "value": ""
    },
    {
      "key": "expectedDuration",
      "value": "0"
    },
    {
      "key": "traineeUsername",
      "value": ""
    },
    {
      "key": "traineePassword",
      "value": ""
    },
    {
      "key": "trainerUsername",
      "value": ""
    },
    {
      "key": "trainerPassword",
      "value": ""
    },
    {
      "key": "traineeToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 Setup",
      "item": [
        {
          "name": "Create Trainee",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Trainee created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('traineeUsername', body.username);",
                  "pm.collectionVariables.set('traineePassword', body.password);",
                  "pm.test('Trainee credentials are returned', function () {",
                  "  pm.expect(body.username).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.password).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"OutboxTrainee{{runId}}\",\n  \"lastName\": \"User\",\n  \"dateOfBirth\": \"1995-05-10\",\n  \"address\": \"Kyiv\"\n}"
            },
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainees",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainees"
              ]
            }
          }
        },
        {
          "name": "Create Trainer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Trainer created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('trainerUsername', body.username);",
                  "pm.collectionVariables.set('trainerPassword', body.password);",
                  "pm.test('Trainer credentials are returned', function () {",
                  "  pm.expect(body.username).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.password).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"OutboxTrainer{{runId}}\",\n  \"lastName\": \"Coach\",\n  \"specialization\": \"Yoga\"\n}"
            },
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainers",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainers"
              ]
            }
          }
        },
        {
          "name": "Login Trainee",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Trainee login succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('traineeToken', body.token);",
                  "pm.test('JWT token is returned', function () {",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{traineeUsername}}\",\n  \"password\": \"{{traineePassword}}\"\n}"
            },
            "url": {
              "raw": "{{gymBaseUrl}}/v1/auth/login",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02 Happy Path Delivery",
      "item": [
        {
          "name": "Add Training While Trainer Workload Is UP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Training creation succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const expectedDuration = Number(pm.collectionVariables.get('expectedDuration') || 0) + 60;",
                  "pm.collectionVariables.set('expectedDuration', String(expectedDuration));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"traineeUsername\": \"{{traineeUsername}}\",\n  \"trainerUsername\": \"{{trainerUsername}}\",\n  \"trainingName\": \"Outbox happy path {{runId}}\",\n  \"trainingTypeName\": \"Yoga\",\n  \"trainingDate\": \"2026-06-21\",\n  \"trainingDuration\": 60\n}"
            },
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainings",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainings"
              ]
            }
          }
        },
        {
          "name": "Wait For Dispatcher",
          "description": "The outbox dispatcher runs on a fixed delay. This request intentionally waits before checking trainer-workload.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const waitUntil = Date.now() + 15000;",
                  "while (Date.now() < waitUntil) {}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gym CRM is healthy', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gymBaseUrl}}/actuator/health",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Verify Trainer Workload Was Updated",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Trainer workload exists', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "const expectedDuration = Number(pm.collectionVariables.get('expectedDuration'));",
                  "const year = (body.years || []).find(function (item) { return item.year === 2026; });",
                  "const month = year && (year.months || []).find(function (item) { return item.month === 6; });",
                  "pm.test('Trainer workload contains expected June 2026 duration', function () {",
                  "  pm.expect(body.trainerUsername).to.eql(pm.collectionVariables.get('trainerUsername'));",
                  "  pm.expect(month, 'June 2026 workload month').to.exist;",
                  "  pm.expect(month.trainingSummaryDuration).to.be.at.least(expectedDuration);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainer-workloads/{{trainerUsername}}",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainer-workloads",
                "{{trainerUsername}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "03 Outbox Retry Manual Scenario",
      "description": "Run this folder one request at a time. Before `Add Training While Trainer Workload Is DOWN`, stop trainer-workload. After that request succeeds, start trainer-workload again and continue.",
      "item": [
        {
          "name": "Manual Step - Stop Trainer Workload",
          "description": "Pause here and run: `docker-compose stop trainer-workload`. Then run the next request.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Manual stop step acknowledged', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "console.warn('Stop trainer-workload now, then run the next request.');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gymBaseUrl}}/actuator/health",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Add Training While Trainer Workload Is DOWN",
          "description": "This request should still return 200 from gym-crm-system. The outbox event should remain PENDING until trainer-workload is back.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Training creation succeeds even while trainer-workload is down', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const expectedDuration = Number(pm.collectionVariables.get('expectedDuration') || 0) + 45;",
                  "pm.collectionVariables.set('expectedDuration', String(expectedDuration));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"traineeUsername\": \"{{traineeUsername}}\",\n  \"trainerUsername\": \"{{trainerUsername}}\",\n  \"trainingName\": \"Outbox retry {{runId}}\",\n  \"trainingTypeName\": \"Yoga\",\n  \"trainingDate\": \"2026-06-21\",\n  \"trainingDuration\": 45\n}"
            },
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainings",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainings"
              ]
            }
          }
        },
        {
          "name": "Manual Step - Start Trainer Workload",
          "description": "Pause here and run: `docker-compose start trainer-workload`. Wait until `http://localhost:8081/api/actuator/health` returns UP, then continue.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Manual start step acknowledged', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "console.warn('Start trainer-workload now, wait for health UP, then run the next request.');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gymBaseUrl}}/actuator/health",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Wait For Retry Dispatcher",
          "description": "Waits long enough for the outbox retry delay and dispatcher fixed delay.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const waitUntil = Date.now() + 45000;",
                  "while (Date.now() < waitUntil) {}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gym CRM is healthy after waiting for retry', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gymBaseUrl}}/actuator/health",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Verify Retried Trainer Workload Update",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Trainer workload is available after retry', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "const expectedDuration = Number(pm.collectionVariables.get('expectedDuration'));",
                  "const year = (body.years || []).find(function (item) { return item.year === 2026; });",
                  "const month = year && (year.months || []).find(function (item) { return item.month === 6; });",
                  "pm.test('Trainer workload includes retried outbox duration', function () {",
                  "  pm.expect(body.trainerUsername).to.eql(pm.collectionVariables.get('trainerUsername'));",
                  "  pm.expect(month, 'June 2026 workload month').to.exist;",
                  "  pm.expect(month.trainingSummaryDuration).to.be.at.least(expectedDuration);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{traineeToken}}"
              }
            ],
            "url": {
              "raw": "{{gymBaseUrl}}/v1/trainer-workloads/{{trainerUsername}}",
              "host": [
                "{{gymBaseUrl}}"
              ],
              "path": [
                "v1",
                "trainer-workloads",
                "{{trainerUsername}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
