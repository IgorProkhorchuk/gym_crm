POSTGRES_USER=postgres
POSTGRES_ROOT_PASSWORD=password

APP_DB_USERNAME=gym_user
APP_DB_PASSWORD=password
APP_DB_NAME=gym_crm
TEST_DB_NAME=gym_crm_test

REPL_PASSWORD=password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

SPRING_PROFILES_ACTIVE=prod

JWT_ISSUER=https://gym-crm.local
JWT_SECRET=GymCrmLocalDevelopmentJwtSecretKeyMustBeAtLeastThirtyTwoBytes
JWT_TOKEN_LIFETIME=PT30M

LOGIN_MAX_FAILED_ATTEMPTS=3
LOGIN_LOCK_DURATION=PT5M

REDIS_HOST=gym-redis
REDIS_PORT=6379

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Default Prometheus config scrapes the containerized gym-app service.
# Use prometheus-host-podman.yml or prometheus-host-docker.yml when the app runs locally on the host.
PROMETHEUS_CONFIG=prometheus.yml
